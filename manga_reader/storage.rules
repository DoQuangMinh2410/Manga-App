// storage.rules
// ════════════════════════════════════════════════════════════════════════════
//  FIREBASE STORAGE RULES — MangaVerse
//  Dán nội dung này vào: Firebase Console → Storage → Rules → Publish
// ════════════════════════════════════════════════════════════════════════════

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Chapter images ─────────────────────────────────────────────────────
    // chapters/{mangaId}/chapter_{n}/page_xxx.jpg
    match /chapters/{mangaId}/{chapterId}/{fileName} {
      // Mọi user đã đăng nhập đọc được ảnh chapter
      allow read: if request.auth != null;

      // Chỉ admin mới upload/xóa ảnh
      // Admin được set field is_admin=true trong Firestore users collection
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
          .data.is_admin == true;
    }

    // Từ chối tất cả các đường dẫn khác
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
